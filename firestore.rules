rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // 1. Settings Document (Public configuration)
    match /config/settings {
      allow read: if true; // Public needs to read settings (e.g. titles, notices, configuration)
      allow write: if false; // Strictly write-blocked for clients (Server/Admin SDK only)
    }
    
    // Sensitive system configuration documents: fully locked down
    match /config/admin-config {
      allow read, write: if false;
    }
    match /config/ai_settings {
      allow read, write: if false;
    }
    
    // 2. Profiles Collection (Public directory)
    match /profiles/{profileId} {
      allow read: if true; // Public directory search & matching needs reading
      
      // Allow users to submit their profile requests
      allow create: if (
        isValidId(profileId) &&
        // Secure Invariant: Registration request MUST be submitted as "pending"
        request.resource.data.status == "pending" &&
        // Type and length validation to prevent malicious inputs
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() <= 150 &&
        request.resource.data.phoneNumber is string &&
        request.resource.data.phoneNumber.size() <= 30
      );
      
      // Lock modifications. Updates, approvals, rejections & deletions can only be made
      // through the admin panel (which uses a secure backend server with Admin privileges).
      allow update, delete: if false;
    }
    
    // 3. System-internal databases: fully secure (Server-side exclusive)
    match /chats/{document=**} {
      allow read, write: if false;
    }
    match /live_messages/{document=**} {
      allow read, write: if false;
    }
    match /temporary_chats/{document=**} {
      allow read, write: if false;
    }
  }
}
